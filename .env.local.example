# ─────────────────────────────────────────────────────────────────────────────
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB (for private messages) ──────────────────────────────────────────
# 1. Go to https://mongodb.com/atlas  →  Create free cluster (M0 — free forever)
# 2. Click "Connect"  →  "Drivers"  →  copy the connection string
# 3. Replace <password> with your database user's password
# 4. Replace myFirstDatabase with:  palak_portfolio
MONGODB_URI=mongodb+srv://palak:<password>@cluster0.xxxxx.mongodb.net/palak_portfolio?retryWrites=true&w=majority

# ── MongoDB database name (optional — default: palak_portfolio) ──────────────
MONGODB_DB=palak_portfolio

# ── Admin secret for reading messages at /api/messages?secret=... ────────────
# Set this to any long random string. Keep it private!
ADMIN_SECRET=change_me_to_something_long_and_random_like_this_abc123xyz

# ── Your contact email (mailto fallback when MongoDB is offline) ─────────────
NEXT_PUBLIC_CONTACT_EMAIL=palak@example.com
